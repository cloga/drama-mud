# LLM Provider
OPENAI_API_KEY=sk-your-key-here
# Optional explicit compatible chat endpoint, e.g. Volcengine Ark
# LLM_BASE_URL=https://ark.example.com/api/v3
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=doubao-seed-1-6-flash-250828
LLM_FALLBACK_MODELS=gpt-5.4-mini
ROOM_STORE_PATH=server/.runtime-data/rooms.json

# Default NPC backend when a room does not specify one
NPC_BACKEND=llm

# Optional shared access code to protect API / WebSocket usage
# DRAMA_MUD_ACCESS_CODE=replace-with-a-shared-secret

# Agent runtime
# Set this when your workspace http-runtime listens on a non-default port.
# OPTIMUS_RUNTIME_BASE_URL=http://127.0.0.1:3100
OPTIMUS_RUNTIME_ROLE_MODEL=gpt-5.4-mini
OPTIMUS_RUNTIME_FALLBACK_MODELS=gpt-5.4

# Server
PORT=3001
NODE_ENV=development

# Client (Vite dev server proxies /api and /ws — only set in production)
# VITE_APP_BASE_PATH=/drama-mud/
# VITE_API_URL=https://your-server.com
# VITE_WS_URL=wss://your-server.com/ws
